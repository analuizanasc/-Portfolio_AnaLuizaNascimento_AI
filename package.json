{
  "name": "recipe-api",
  "version": "1.0.0",
  "description": "API REST para gerenciamento de caderno de receitas",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit",
    "test:verbose": "jest --coverage --verbose --forceExit",
    "test:api": "mocha 'tests/api/**/*.spec.js' --timeout 10000 --exit",
    "test:api:report": "mocha 'tests/api/**/*.spec.js' --timeout 10000 --exit --reporter mochawesome --reporter-options reportDir=reports/mocha,reportFilename=recipe-api-report,overwrite=true"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "jest": "^29.0.0",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/api/",
      "/tests/performance/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/test/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 100,
        "branches": 100,
        "functions": 100,
        "lines": 100
      }
    }
  }
}
